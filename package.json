{
  "name": "copydog",
  "version": "0.1.0",
  "private": true,
  "description": "The collaborative copy editor and wireframe tool",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:reset": "supabase db reset",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "packageManager": "pnpm@9.15.9",
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.2",
    "drizzle-orm": "^0.45.2",
    "geist": "^1.7.2",
    "next": "^16.2.10",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.17",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
